#!/usr/bin/zsh
RESET="\033[m"
RED_FG="\033[31m"
GREEN_FG="\033[32m"
YELLOW_FG="\033[33m"
BLUE_FG="\033[34m"
MAGENTA_FG="\033[35m"
CYAN_FG="\033[36m"
WHITE_FG="\033[37m"
BOLD="\033[1m"

E_RESET=$(echo -n "\033[m")
E_GREEN_FG=$(echo -n "\033[32m")
E_RED_FG=$(echo -n "\033[31m")
E_MAGENTA_FG=$(echo -n "\033[35m")

# Imports
[[ -z ${ZSH_LIB_DIR} ]] && _LIB_DIR=/usr/local/lib || _LIB_DIR=${ZSH_LIB_DIR}
source ${_LIB_DIR}/LIB_INIT.zsh # Must be first
source ${_LIB_DIR}/UTILS.zsh
source ${_LIB_DIR}/LIB_DEPS.zsh # Must be last

# Declarations
typeset -a _TZ=(Los_Angeles Denver Chicago New_York)
typeset -a _ZONES=()
typeset -a _LIST=()
typeset -i _HOUR_DIFF=0
typeset -i _UTS_DIFF_VAL=0

# Vars
_LONGEST=0

# Constants
_ZPATH=/usr/share/zoneinfo
_EXCLUDE="${_ZPATH:t}|posix|right|SystemV|Etc"
_LOCAL_TIME=$(date +"%T")
_LOCAL_DATE=$(date +"%D")
_LOCAL_ZONE=$(date +"%Z")
_UTC_TIME=$(date -u +"%T")
_UTC_DATE=$(date -u +"%D")
_UTC_HOUR=$(date -u +"%H")
_UTC_DIFF=$(date +"%z")

# Functions
rep () {
	local CHAR=${1}
	local LENGTH=${2}
	local LINE=''
	local X

	for ((X=0;X < ${LENGTH};X++));do
		LINE=${LINE}''${CHAR}
	done

	echo ${LINE}
}

do_list () {
	local D=${1}

	echo "\n"
	HDR="${D:t}:"
	echo ${WHITE_FG}${HDR}${RESET}
	echo $(rep - ${#HDR})
	/bin/ls --color=always -LXNv --group-directories-first ${D}
}

list () {
	local HDR
	local L

	_LIST=($(find ${_ZPATH} -maxdepth 2))

	for L in ${_LIST};do
		if [[ -d ${L} && ! ${L:t} =~ ${_EXCLUDE} ]];then
			do_list ${L}
		fi
	done
}

#--Begin GetOpts--
RESET="\033[m"
RED_FG="\033[31m"
WHITE_FG="\033[37m"

SCRIPT=${0:t}
parse_opts () {
	local OPTS=$@
	local O

	local -a OPTSTR
	for O in {1..${#OPTS}};do
		[[ $O -eq 1 && ${OPTS[$O]} == ":" ]] && continue
		[[ $O -gt 1 && ${OPTS[$O]} == ":" ]] && OPTSTR+="<PARAM>" && continue
		OPTSTR+="-${OPTS[$O]}"
	done
	echo $OPTSTR
}

usage () {
	local OPTS=$(parse_opts $OPTSTR)
	local -a PENDING_MSGS=(${@})

	(
	echo -e "\n${WHITE_FG}Usage${RESET}: $SCRIPT ${WHITE_FG}[${RESET} $OPTS ${WHITE_FG}]${RESET} <_TZ>\n"
	echo -e "${WHITE_FG}-H${RESET} help"
	echo -e "${WHITE_FG}-D${RESET} debug"
	echo -e "${WHITE_FG}-l${RESET} list zones"
	echo -e "\n${WHITE_FG}Desc${RESET}:Show times in other zones. Accepts _TZ id as an argument.  Default is USA\n"
	) >&2

	exit_leave $(err_msg_exit ${PENDING_MSGS})
}

OPTSTR=":HDl"

OPTIND=0
while getopts ${OPTSTR} OPTION;do
	case $OPTION in
     H) usage;;
     D) dbg_set_level;;
     l) list;exit;;
     :) print -u2 "${SCRIPT}: option: -${OPTARG} requires an argument"; usage;;
    \?) print -u2 "${SCRIPT}: ${BOLD}${RED_FG}Unknown option${RESET} -${OPTARG}"; usage;;
	esac
done
shift $(( OPTIND - 1 ))
#--End GetOpts--

#--Execution--
[[ -n $1 ]] &&_TZ=$1 # Use _TZ defaults or arg if present

for Z in ${_TZ};do
	_LIST+=($(find ${_ZPATH} -iname "*${Z}*"))
	[[ -z ${_LIST[1]} ]] && echo "${RED_FG}Error${RESET}:No time zone(s) matching ${WHITE_FG}[${RESET} ${BOLD}${_TZ}${RESET} ${WHITE_FG}]${RESET} were found" && exit_leave
done

for L in ${_LIST};do
	[[ ${L} =~ '\.list' ]] && continue
	[[ ${L} =~ '\.tab' ]] && continue
	[[ ${L} =~ 'right' ]] && continue
	[[ ${L} =~ 'Factory' ]] && continue
	[[ ${L} =~ 'posix' ]] && continue
	[[ ${L} =~ 'local' ]] && continue
	[[ ${L} =~ 'leap' ]] && continue
	[[ ${L} =~ 'Etc' ]] && continue
	[[ ${L} =~ 'MT' ]] && continue
	[[ ${L} =~ 'ST' ]] && continue
	[[ ${L} =~ 'DT' ]] && continue
	[[ ${L} =~ "^${_ZPATH}$" ]] && continue
	_ZONES+=${${L}##${_ZPATH}/}
	[[ ${#${L}##${_ZPATH}/} -gt ${_LONGEST} ]] && _LONGEST=${#${L}##${_ZPATH}/}
done

_UTS_DIFF_VAL=$(date +"%:::z")

[[ ${_UTC_DIFF} =~ "^\+" ]] && _UTC_LBL="ahead" || _UTC_LBL="behind"
[[ ${_UTS_DIFF_VAL} -eq 1 ]] && HP='' || HP='s'

if [[ ${_DEBUG} -gt 0 ]];then
	dbg "${0}:${LINENO} --> _LOCAL_TIME:${_LOCAL_TIME}"
	dbg "${0}:${LINENO} --> _UTC_DIFF:${_UTC_DIFF}"
	dbg "${0}:${LINENO} --> _UTS_DIFF_VAL:${_UTS_DIFF_VAL}"
	dbg "${0}:${LINENO} --> _UTC_LBL:${_UTC_LBL}"
	dbg "${0}:${LINENO} --> _UTC_TIME:${_UTC_TIME}"
fi

echo "   _LOCAL:${WHITE_FG}${_LOCAL_TIME} ${CYAN_FG}${_LOCAL_ZONE}${RESET} ${_LOCAL_DATE}"
echo "_UTC(GMT):${WHITE_FG}${_UTC_TIME}${RESET} ${_UTC_DATE} (you are ${_UTS_DIFF_VAL} hour${HP} ${_UTC_LBL})\n"

# Typeset -i _TZ_DIFF

for Z in ${_ZONES};do
	_TZ_HEAD=$(_TZ=${Z} date +"%A, %B %d %Y,")
	_TZ_DATE=$(_TZ=${Z} date +"%D")
	_TZ_TIME=$(_TZ=${Z} date +"%I:%M")
	_TZ_AMPM=$(_TZ=${Z} date +"%p")
	_TZ_TAIL=$(_TZ=${Z} date +"%Z")
	_TZ_DIFF=$(_TZ=${Z} date +"%z")

	[[ ${_TZ_AMPM} == "AM" ]] && _TZ_AMPM="${E_GREEN_FG}${_TZ_AMPM}${E_RESET}" || _TZ_AMPM="${E_RED_FG}${_TZ_AMPM}${E_RESET}"

	if [[ ${_DEBUG} -gt 0 ]];then
		dbg "${0}:${LINENO} ZONE:${Z}"
		dbg "${0}:${LINENO} _TZ_HEAD=\$(_TZ=\${Z} date +\"\%A, \%B \%d \%Y,\")"
		dbg "${0}:${LINENO} --> _TZ_HEAD=${_TZ_HEAD}"
		dbg "${0}:${LINENO} _TZ_TAIL=\$(_TZ=${Z} date +"%Z")"
		dbg "${0}:${LINENO} --> _TZ_TAIL=${_TZ_TAIL}"
		dbg "${0}:${LINENO} _TZ_DATE=\$(_TZ=${Z} date +"%D")"
		dbg "${0}:${LINENO} --> _TZ_DATE=${_TZ_DATE}"
		dbg "${0}:${LINENO} _TZ_TIME=\$(_TZ=${Z} date +"%I:%M")"
		dbg "${0}:${LINENO} --> _TZ_TIME=${_TZ_TIME}"
		dbg "${0}:${LINENO} _TZ_AMPM=\$(_TZ=${Z} date +"%p")"
		dbg "${0}:${LINENO} --> _TZ_AMPM=${_TZ_AMPM}"
		dbg "${0}:${LINENO} _TZ_DIFF=\$(_TZ=${Z} date +"%z")"
		dbg "${0}:${LINENO} --> _TZ_DIFF=${_TZ_DIFF}"
	fi
	
	_TZ_DIFF_VAL=${_TZ_DIFF[1,3]}
	_UTS_DIFF_VAL=${_UTC_DIFF[1,3]}
	(( _HOUR_DIFF = _TZ_DIFF_VAL - _UTS_DIFF_VAL ))

	if [[ ${_DEBUG} -gt 0 ]];then
		dbg "${0}:${LINENO} --> _HOUR_DIFF = ${_TZ_DIFF_VAL} - ${_UTS_DIFF_VAL}"
		dbg "${0}:${LINENO} --> _HOUR_DIFF:${_HOUR_DIFF}"
		dbg "${0}:${LINENO} --> _TZ_DIFF_VAL:${_TZ_DIFF_VAL}"
		dbg "${0}:${LINENO} --> _UTS_DIFF_VAL:${_UTS_DIFF_VAL}"
	fi

	if [[ ${_HOUR_DIFF} -gt 0 ]];then
		HOUR_LBL="behind"
	elif [[ ${_HOUR_DIFF} -lt 0 ]];then
		HOUR_LBL="ahead"
	fi

	if [[ ${_DEBUG} -gt 0 ]];then
		dbg "${0}:${LINENO} --> HOUR_LBL:${HOUR_LBL}"
		dbg "${0}:${LINENO} --> _TZ_DIFF_VAL:${_TZ_DIFF_VAL} _UTS_DIFF_VAL:${_UTS_DIFF_VAL}"
	fi

	[[ ${_TZ_DIFF} =~ "^-" ]] && (( _HOUR_DIFF = _TZ_DIFF_VAL - _UTS_DIFF_VAL )) && _HOUR_DIFF=$(echo ${_HOUR_DIFF} | tr -d -) && DIFF_LBL="You [${E_MAGENTA_FG}${_LOCAL_ZONE}${E_RESET}] are ${_HOUR_DIFF} hours ${HOUR_LBL}"
	[[ ${_TZ_DIFF} =~ "^\+" ]] && (( _HOUR_DIFF = _TZ_DIFF_VAL - _UTS_DIFF_VAL )) && DIFF_LBL="You [${E_MAGENTA_FG}${_LOCAL_ZONE}${E_RESET}] are ${_HOUR_DIFF} hours ${HOUR_LBL}"
	[[ ${_HOUR_DIFF} -lt 0 ]] && _HOUR_DIFF=$(echo ${_HOUR_DIFF} | tr -d -) && DIFF_LBL="You [${E_MAGENTA_FG}${_LOCAL_ZONE}${E_RESET}] are ${_HOUR_DIFF} hours ${HOUR_LBL}"
	[[ ${_HOUR_DIFF} -eq 0 ]] && DIFF_LBL="You [${E_MAGENTA_FG}${_LOCAL_ZONE}${E_RESET}] have the same time"
	[[ ${_HOUR_DIFF} -eq 1 ]] && DIFF_LBL=$(echo ${DIFF_LBL} | sed 's/hours/hour/g')

	printf "In the ${WHITE_FG}%*s${RESET} ${CYAN_FG}%3s${RESET} time zone it is %20s at ${WHITE_FG}%5s${RESET} %2s (%s)\n" ${_LONGEST} ${Z} ${_TZ_TAIL} ${_TZ_HEAD} ${_TZ_TIME} ${_TZ_AMPM} ${DIFF_LBL}
done

exit_leave
