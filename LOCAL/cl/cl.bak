#!/usr/bin/zsh

# Inline ansi
BOLD="\033[1m"
ITALIC="\033[3m"
RESET="\033[m"
REVERSE="\033[7m"
STRIKE="\033[9m"
UNDER="\033[4m"

BLACK_BG="\033[40m"

BLUE_FG="\033[34m"
CYAN_FG="\033[36m"
GREEN_FG="\033[32m"
MAGENTA_FG="\033[35m"
RED_FG="\033[31m"
WHITE_FG="\033[37m"
YELLOW_FG="\033[33m"

WHITE_ON_GREY="\033[0m\033[0;1;37;100m"
  
typeset -a _LOCAL_FILES

_CODEBASE=~/Code
_LOCAL=${_CODEBASE}/_LOCAL
_LANG=${_CODEBASE}/_LANG
_PYPROJ=${_LANG}/Python/PROJECTS

if [[ ${1} == '-H' ]];then
	tabs 5
	echo "\n${WHITE_FG}Usage${RESET}:${0:t} [-H] [<dir>]"
	echo "${WHITE_FG} Desc${RESET}:Change to development directory\n"
	echo "Directories searched:\n"
	echo "${_CODEBASE}"
	echo "${_LOCAL}"
	echo "${_LANG}"
	echo "${_PYPROJ}"
	echo
	return
fi

[[ -z ${1} ]] && cd ${_CODEBASE}

if [[ -d ${_LOCAL}/${1} ]];then
	cd ${_LOCAL}/${1} 
elif [[ -d ${_LOCAL}/${(U)1} ]];then
	cd ${_LOCAL}/${(U)1} 
elif [[ -d ${_LANG}/${1} ]];then
	cd ${_LANG}/${1} 
elif [[ -d ${_LANG}/${(U)1} ]];then
	cd ${_LANG}/${(U)1} 
elif [[ -d ${_CODEBASE}/${1} ]];then
	cd ${_CODEBASE}/${1} 
elif [[ -d ${_CODEBASE}/${(U)1} ]];then
	cd ${_CODEBASE}/${(U)1} 
elif [[ -d ${_PYPROJ}/${1} ]];then
	cd ${_PYPROJ}/${1} 
	[[ -d venv ]] && cd venv
elif [[ -d ${_PYPROJ}/${(U)1} ]];then
	cd ${_PYPROJ}/${(U)1} 
	[[ -d venv ]] && cd venv
else
	echo "No development directory found:${WHITE_FG}${1}${RESET}"
	return
fi

{
	LONGEST=0
	for F in ${PWD}/*;do
		[[ ${F:e} == 'bak' ]] && continue
		if [[ $(file ${F}) =~ 'zsh script' || ${F:e} == 'zsh' || ${F:e} == 'js' ]];then
			_LOCAL_FILES+=${F}
			[[ ${#F} -gt ${LONGEST} ]] && LONGEST=${#F}
		fi
	done
} >/dev/null 2>&1

if [[ -n ${_LOCAL_FILES} ]];then
	for F in ${_LOCAL_FILES};do
		PROD=$(fut findexe ${F} 2>&1)
		[[ -z ${PROD} || ${PROD:l} =~ "not found" ]] && continue # No production version exists
		if [[ ! ${PROD:l} =~ 'code/local' ]];then
			diff -b ${F} ${PROD} >/dev/null 2>&1
			if [[ ${?} -ne 0 ]];then
				printf "Development:${WHITE_FG}%*s${RESET} ${BOLD}${RED_FG}%-15s${RESET} Production:${WHITE_FG}%s${RESET}\n" ${LONGEST} ${F}   'does not match' ${PROD}
			else
				printf "Development:${WHITE_FG}%*s${RESET} ${BOLD}${GREEN_FG}%-15s${RESET} Production:${WHITE_FG}%s${RESET}\n" ${LONGEST} ${F} '       matches' ${PROD}
			fi
		fi
	done
fi
