	local FILTER="--filter=\"merge ${REPO_FLTR}\"" # Set filter option

	echo "${GREEN_FG}SYSTEM FILES${RESET}" >&2
	echo "rsync -ar --no-links ${FILTER} ${_SRC_USR_LOCAL_BIN_SYS} ${_REPO_SYSTEM}"
	eval "rsync -ar --no-links ${FILTER} ${_SRC_USR_LOCAL_BIN_SYS} ${_REPO_SYSTEM}"
