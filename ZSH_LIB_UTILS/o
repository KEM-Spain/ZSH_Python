#!/usr/bin/zsh
REVERSE="\033[7m"
RESET="\033[m"
BOLD="\033[1m"
BLACK_FG="\033[30m"
RED_FG="\033[31m"
GREEN_FG="\033[32m"
YELLOW_FG="\033[33m"
BLUE_FG="\033[34m"
MAGENTA_FG="\033[35m"
CYAN_FG="\033[36m"
WHITE_FG="\033[37m"
STRIKE="\033[9m"
ITALIC="\033[3m"
UNDER="\033[4m"

# Echoed ansi colors
E_REVERSE=$(echo "\033[7m")
E_RESET=$(echo "\033[m")
E_BOLD=$(echo "\033[1m")
E_BLACK_FG=$(echo "\033[30m")
E_RED_FG=$(echo "\033[31m")
E_GREEN_FG=$(echo "\033[32m")
E_YELLOW_FG=$(echo "\033[33m")
E_BLUE_FG=$(echo "\033[34m")
E_MAGENTA_FG=$(echo "\033[35m")
E_CYAN_FG=$(echo "\033[36m")
E_WHITE_FG=$(echo "\033[37m")
E_STRIKE=$(echo "\033[9m")

typeset -a DEPS=(LIST.zsh)

# Imports
[[ -z ${ZSH_LIB_DIR} ]] && _LIB_DIR=/usr/local/lib || _LIB_DIR=${ZSH_LIB_DIR}
source ${_LIB_DIR}/LIB_INIT.zsh
source ${_LIB_DIR}/LIB_DEPS.zsh ${DEPS}

# Declarations
typeset -A _APP_EXE
typeset -A _APP_WIN
typeset -A _FILE_APP
typeset -A _FILE_NDX
typeset -A _FILE_WIN
typeset -a _ARG_LIST=()
typeset -a _FOREGROUND_ONLY=(vim)
typeset -a _LOCAL_LIST=()
typeset -a _MARKED=()
typeset -a _RAWLIST=()

# Constants
_CFG_DIR=~/.local/share/${_SCRIPT}
_APP_LOG=${_CFG_DIR}/${_SCRIPT}.log
_ERR_LOG=${_CFG_DIR}/err.log

_APP_EXE[EBOOK]="/usr/bin/foliate"
_APP_EXE[OKULAR]=/usr/bin/okular
_APP_EXE[MDLESS]=/usr/local/bin/mdless
_APP_EXE[MUSE]="/usr/local/bin/system/launchers/run_musescore"
_APP_EXE[OFFICE]=/usr/bin/libreoffice
_APP_EXE[IMAGE]=/usr/local/bin/viewnior
_APP_EXE[VLC]="/usr/bin/vlc --no-qt-error-dialogs --verbose 0"
_APP_EXE[CLEM]="/usr/bin/clementine"
_APP_EXE[HARUNA]=/snap/bin/haruna
_APP_EXE[MPV]="/usr/bin/mpv --fs --loop-file=inf --volume=40 --msg-level=all=error"
_APP_EXE[VIM]=/usr/bin/vim

_APP_WIN[EBOOK]="ebook-viewer"
_APP_WIN[OKULAR]="okular"
_APP_WIN[MUSE]="musescore"
_APP_WIN[OFFICE]="libreoffice"
_APP_WIN[IMAGE]="viewnior"
_APP_WIN[VLC]="vlc"
_APP_WIN[CLEM]="clementine"
_APP_WIN[HARUNA]="haruna"
_APP_WIN[MPV]="mpv"
_APP_WIN[VIM]="vim"

_MD_EXTERNAL="/media/${USER}/KEM_Misc/Music/KEM-B9"
_MD_LOCAL="${HOME}/Documents/Music"
_MD_MUSE="${HOME}/Documents/MuseScore4/Scores"

_UNSUPPORTED=3

# Functions
action_do () {
	local -a _MARKED=(${@})
	local -A RUN_LIST=()
	local -A FILE_APP=()
	local -a FLIST=()
	local APP_EXE_PATH
	local APP_WIN
	local CMD
	local CMD_PID
	local FN
	local IN_APP=false
	local LAST_APP=?
	local MSG=''
	local RC=''
	local M K

	[[ ${_DEBUG} -gt 0 ]] && dbg "${functrace[1]} called ${0}:${LINENO}: ARGC:${#@}"

	for M in ${_MARKED};do
		FN=${(k)_FILE_NDX[(r)${M}]}
		APP_EXE_PATH=${_FILE_APP[${FN}]}
		APP_WIN=${_FILE_WIN[${FN}]}
		FILE_APP[${FN}]=${APP_EXE_PATH}
	done

	[[ ${_DEBUG} -gt 0 ]] && dbg "CMD:${CMD}"

	for K in ${(k)FILE_APP};do # Allow each app to have a unique filelist
		if [[ ${FILE_APP[${K}]} != "${LAST_APP}" ]];then
			LAST_APP=${FILE_APP[${K}]}
			FLIST=()
			FLIST+=${(qqq)K}
		else
			FLIST+=${(qqq)K}
		fi
		RUN_LIST[${LAST_APP}]=${FLIST} # Collect cmd & args
	done

	for K in ${(k)RUN_LIST};do
		/bin/rm -f ${_ERR_LOG}
		if is_foreground_only ${K};then
			logit ${_APP_LOG} "${0}: Executing foreground job: APP:${K} ARGS:${RUN_LIST[${K}]}"
			eval "${K} ${RUN_LIST[${K}]} 2>${_ERR_LOG}" # Foreground
			MSG=$(grep --color=never -Esi 'fail|error' ${_ERR_LOG})
			RC=$(wc -w <<<${MSG})
			[[ ${RC} -ne 0 ]] && msg_box -p "<B><I>${0}: ${APP} returned an error<N>| |<r>$(<${_ERR_LOG})<N>| |<w>Press any key...<N>"
		else
			logit ${_APP_LOG} "${0}: Executing background job: APP:${K} ARGS:${RUN_LIST[${K}]}"
			eval "${K} ${RUN_LIST[${K}]} 2>${_ERR_LOG} &" # Background
			win_max -p ${!} # Maximize window using PID of background job
			MSG=$(grep --color=never -Esi 'fail|error' ${_ERR_LOG})
			RC=$(wc -w <<<${MSG})
		fi
	done

	for M in ${_MARKED};do
		[[ ${M} -eq 0 ]] && continue
		_MARKED[${M}]=0
		list_set_selected ${M} ${_STALE_ROW}
	done
}

action_warn () {
	local _MARKED=(${@})
	local CNT=$(list_get_selected_count ${_MARKED})
	local M
	
	msg_box -p "<I>Please respond<N>|==============| |${CNT} $(str_pluralize item $CNT) queued for opening.| |<B>Open? (y/n)<N>"
	if [[ ${_MSG_KEY} == 'n' ]];then
		for M in ${_MARKED};do
			list_clear_selected ${M}
		done
	fi
}

get_app () {
	local FN=${1}
	local EXT=${FN:e:l}
	local APP=$(map_ext ${EXT})
	
	if [[ ${APP} == '?' ]];then
		if [[ -n ${FN} && $(file ${FN}) =~ "text" ]];then
			APP=${_APP_EXE[VIM]} # Editable unknown extensions 
		fi
	fi

	logit ${_APP_LOG} "${0}: ${FN} assigned to $(cut -d' ' -f1 <<<${APP})"

	echo ${APP}
}

get_win () {
	local FN=${1}
	local EXT=${FN:e:l}
	local APP_WIN=$(map_ext ${EXT})
	
	if [[ ${APP_WIN} == '?' ]];then
		if [[ -n ${FN} && $(file ${FN}) =~ "text" ]];then
			APP_WIN=${_APP_WIN[VIM]} # Editable unknown extensions 
		fi
	fi

	logit ${_APP_LOG} "${0}: ${FN} assigned to $(cut -d' ' -f1 <<<${APP_WIN})"

	echo ${APP_WIN}
}

is_foreground_only () {
	local APP=${1}
	local A

	APP=$(cut -d' ' -f1 <<<${APP}) # Isolate APP name

	for A in ${_FOREGROUND_ONLY};do
		if [[ ${APP} =~ ${A} ]];then
			logit ${_APP_LOG} "${0}: ${APP} designated foreground app"
			return 0
		else
			return 1
		fi
	done
}

item_decorate () {
	local NDX=$1
	local FN=${_LOCAL_LIST[${NDX}]}

	case ${_LIST_SELECTED[${NDX}]} in
		${_STALE_ROW}) echo -n "${E_STRIKE}${E_RED_FG}${FN}${E_RESET} ${E_ITALIC}viewed${E_RESET}";;
		${_UNSUPPORTED}) echo -n "${E_STRIKE}${E_RED_FG}${FN}${E_RESET} ${E_ITALIC}unsupported${E_RESET}";;
		*)	tput el;echo -n ${FN};;
	esac
}

map_ext () {
	local EXT=${1}
	local APP=''

	case ${EXT} in
		avi) APP=${_APP_EXE[MPV]};;
		doc) APP=${_APP_EXE[OFFICE]};;
		epub) APP=${_APP_EXE[EBOOK]};;
		flac) APP=${_APP_EXE[CLEM]};;
		gif) APP=${_APP_EXE[IMAGE]};;
		html) APP=${_APP_EXE[VIM]};;
		jpeg) APP=${_APP_EXE[IMAGE]};;
		jpg) APP=${_APP_EXE[IMAGE]};;
		log) APP=${_APP_EXE[VIM]};;
		m4a) APP=${_APP_EXE[MPV]};;
		markdown) APP=${_APP_EXE[MDLESS]};;
		md) APP=${_APP_EXE[MDLESS]};;
		mov) APP=${_APP_EXE[VLC]};;
		mkv) APP=${_APP_EXE[MPV]};;
		mp3) APP=${_APP_EXE[CLEM]};;
		mp4) APP=${_APP_EXE[MPV]};;
		mscz) APP=${_APP_EXE[MUSE]};;
		odg) APP=${_APP_EXE[OFFICE]};;
		ods) APP=${_APP_EXE[OFFICE]};;
		odt) APP=${_APP_EXE[OFFICE]};;
		pdf) APP=${_APP_EXE[OKULAR]};;
		png) APP=${_APP_EXE[IMAGE]};;
		rtf) APP=${_APP_EXE[OFFICE]};;
		svg) APP=${_APP_EXE[IMAGE]};;
		txt) APP=${_APP_EXE[VIM]};;
		wav) APP=${_APP_EXE[CLEM]};;
		webm) APP=${_APP_EXE[MPV]};;
		xls) APP=${_APP_EXE[OFFICE]};;
		*) APP=?;;
	esac

	echo ${APP}
}

mark_unsupported () {
	local NDX=$1
	local SUPPORTED

	SUPPORTED=$(get_app ${_LOCAL_LIST[${NDX}]})
	if [[ ${SUPPORTED} == '?' ]];then
		_LIST_SELECTED[${NDX}]=${_UNSUPPORTED}
		logit ${_APP_LOG} "${0}: ${APP} marked as unsupported"
	fi
}

lcase_mp4 () {
	FN=${1}
	mv -f ${FN} ${FN:r}.mp4
	logit ${_APP_LOG} "${0}: Lower cased extension ${FN}"
}

same_extension () {
	local _MARKED=(${@})
	local SAME_EXT=true
	local LAST_EXT=?
	local M

	for M in ${_MARKED};do
		[[ ! -f ${_LOCAL_LIST[${M}]} ]] && continue
		[[ ${LAST_EXT} == "?" ]] && LAST_EXT=${_LOCAL_LIST[${M}]:e}
		[[ ${LAST_EXT} != ${_LOCAL_LIST[${M}]:e} ]] && SAME_EXT=false
	done

	if [[ ${SAME_EXT} == 'true' ]];then
		logit ${_APP_LOG} "${0}: identified same extension ${LAST_EXT}"
		return 0
	else
		return 1
	fi
}

single_file_launch () {
	local FN=${1}
	local APP=$(get_app ${FN})
	local APP_WIN=$(get_win ${FN})

	[[ ${APP} == '?' ]] && exit_leave $(err_msg_exit "No application to handle file:${FN} of type: [$(file -b ${FN})]")

	[[ -e ${PWD}/${FN:t} ]] && _LIST+=${FN:t} || _LIST+=$(realpath ${FN}) 

	_FILE_APP[${F}]=${APP}
	_FILE_NDX[${F}]=1
	_FILE_WIN[${F}]=${APP_WIN}

	echo "_LIST:${_LIST}"
	echo "_FILE_APP:${_FILE_APP}"
	echo "_FILE_NDX:${_FILE_NDX}"
	echo "_FILE_WIN:${_FILE_WIN}"

	logit ${_APP_LOG} "${0}: Launching single file:${FN}"

	action_do 1
}

#--Begin GetOpts--
local -a OPTIONS
local OPTION
local DESC

read -r -d '' DESC<<EOF
Open selected file with associated application
EOF

parse_opts () {
	local OPTS=${@}
	local -a OPTSTR
	local LETTER_OPT
	local O

	for O in {1..${#OPTS}};do
		[[ ${OPTS[${O}]} =~ '[A-Za-z]' ]] && LETTER_OPT=${OPTS[${O}]}
		[[ ${O} -eq 1 && ${OPTS[${O}]} == ":" ]] && continue
		[[ ${O} -gt 1 && ${OPTS[${O}]} == ":" ]] && OPTSTR+=$(opt_type ${LETTER_OPT}) && continue
		OPTSTR+="-${OPTS[${O}]}"
	done
	echo ${OPTSTR}
}

opt_exists () {
	local OPT=${1}
	[[ $(( $OPTIONS[(Ie)${OPT}] )) -ne 0 ]] && return 0 || return 1
}

opt_type () {
	local OPT=${1}
	case ${OPT} in
		d) echo "<DIR>";;
		f) echo "<FILE>";;
		t) echo "<FILE_TYPE>";;
	esac
}

usage () {
	local -a PENDING_MSGS=(${@})
	local OPTS=$(parse_opts ${OPTSTR})

	[[ ${_SMCUP} == 'true' ]] && do_rmcup

	tabs 5
	(
	echo -e "\n${WHITE_FG}\nUsage${RESET}: ${_SCRIPT} ${WHITE_FG}[${RESET}${OPTS}${WHITE_FG}]${RESET} [$(opt_type d)|$(opt_type f)]\n"
	echo -e "${WHITE_FG}-H${RESET} help"
	echo -e "${WHITE_FG}-D${RESET} debug (repeats increase level)"
	echo -e "${WHITE_FG}-a${RESET} show unsupported files"
	echo -e "\n${WHITE_FG}Desc${RESET}:${DESC}"
	) >&2

	exit_leave $(err_msg_exit ${PENDING_MSGS})
}

OPTSTR=":HDat"
OPTIND=0

FILTER_UNSUPPORTED=true
FILTER="Supported Only"
TEST=false

while getopts ${OPTSTR} OPTION;do
	case $OPTION in
     H) usage;;
     D) dbg_set_level;;
     a) FILTER_UNSUPPORTED=false;FILTER="All Files";;
     t) TEST=true;;
     :) print -u2 "${RED_FG}${_SCRIPT}${RESET}: option: -${OPTARG} requires an argument"; usage;;
    \?) print -u2 "${RED_FG}${_SCRIPT}${RESET}: ${BOLD}${RED_FG}Unknown option${RESET} -${OPTARG}"; usage;;
	esac
	[[ ${OPTION} != 'D' ]] && OPTIONS+=${OPTION}
done
shift $(( OPTIND - 1 ))
#--End GetOpts--

#--Execution
[[ ${_DEBUG} -eq 0 ]] && do_smcup
[[ ! -d ${_CFG_DIR} ]] && mkdir ${_CFG_DIR}
[[ -e ${_APP_LOG} ]] && /bin/rm -f ${_APP_LOG} # Initialize logging

MUSIC_DIRS=false
[[ -e ${_MD_EXTERNAL} ]] && MUSIC_DIRS=true
[[ -e ${_MD_LOCAL} ]] && MUSIC_DIRS=true
[[ -e ${_MD_MUSE} ]] && MUSIC_DIRS=true

RAWPATH=$(path_get_raw)
FPATH=$(cut -d'|' -f1 <<<${RAWPATH})
FPATH=${FPATH:q}
FGLOB=$(cut -d'|' -f2 <<<${RAWPATH})
PATHLBL=$(path_get_label 40)

# Command line args
# 0) none - all files in PWD
# 1) file - process a single file
# *) list - process a list of files
case ${#} in
	0) HDR_MSG="Showing all files in:$(pathabv <<<${PWD})"
		CMD="find ${FPATH} -maxdepth 1 -type f ! -path ${FPATH}"
		_ARGLIST=("${(f)$(eval ${CMD})}")
		;;
	1) _ARGLIST+=${1};;
	*) HDR_MSG='Processing file list'
		_ARGLIST=(${@})
		;;
esac

NDX=0
for F in ${_ARGLIST};do
	[[ ! -e ${F} ]] && exit_leave $(err_msg_exit E "File:${F} not found")
	[[ -d ${F} ]] && continue # Skip any directories
	((NDX++))
	[[ -e ${PWD}/${F:t} ]] && _RAWLIST[${NDX}]=${F:t} || _RAWLIST[${NDX}]=$(realpath ${F}) 
done

if ! arr_is_populated "${_RAWLIST}";then
	exit_leave $(err_msg_exit "No qualified candidates")
fi

logit ${_APP_LOG} "Args provided ${#_RAWLIST} candidates"

NDX=0
for F in ${(o)_RAWLIST};do # Marshal apps
	FN=${F}
	[[ ${FN:e} == 'MP4' ]] && { lcase_mp4 ${FN} && FN="${FN:r}.${FN:e:l}" }
	APP=$(get_app ${FN})
	APP_WIN=$(get_win ${FN})
	[[ ${APP} == '?' && ${FILTER_UNSUPPORTED} == 'true' ]] && continue # Skip any unsupported
	((NDX++))
	if [[ ${MUSIC_DIRS} == 'true' ]];then
		FN=${F}
		[[ ${#FN} -eq ${#F} ]] && FN=${${FN}##${_MD_EXTERNAL}}
		[[ ${#FN} -eq ${#F} ]] && FN=${${FN}##${_MD_LOCAL}}
		[[ ${#FN} -eq ${#F} ]] && FN=${${FN}##${_MD_MUSE}}
		[[ ${#FN} -eq ${#F} ]] && FN=${FN}
	else
		FN=${F:t}
	fi
	_LOCAL_LIST+=${FN}
	mark_unsupported ${NDX}
	_FILE_APP[${F}]=${APP}
	_FILE_NDX[${F}]=${NDX}
	_FILE_WIN[${F}]=${APP_WIN}
done

logit ${_APP_LOG} "Validated ${#_LOCAL_LIST} candidates"

if [[ -z ${_LOCAL_LIST} ]];then
	do_rmcup
	for F in ${(on)_RAWLIST};do
		echo "${RED_FG}No application${RESET} to handle file:${WHITE_FG}${F:t}${RESET} of type: [$(file -b ${F})]"
	done
	exit_leave
fi

if [[ ${#_LOCAL_LIST} -eq 1 ]];then # Process a single file arg directly
	_LIST=(${_LOCAL_LIST})
	action_do 1
	exit_leave
fi

# Set headings
list_set_header 'printf "Found:${WHITE_FG}%-d${RESET} $(str_pluralize file ${#_LIST})  ${WHITE_FG}%-*s${RESET}  Filter:${WHITE_FG}%s${RESET}  Selected:${WHITE_FG}%*d${RESET}  ${_PG}" ${#_LIST} ${#HDR_MSG} "${HDR_MSG}" "${FILTER}" ${#${#SELECTED_COUNT}} ${SELECTED_COUNT}'
list_add_header_break

# Set line item
list_set_line_item ' 
printf "${BOLD}${GREEN_FG}%4s${RESET}${_MARKER} ${SHADE}${BAR}%s${RESET}\n" ${_LIST_NDX} "$(item_decorate ${_LIST_NDX})" 
'

list_set_select_action "open"
list_set_action_msgs open file
list_set_reuse_stale true
list_set_client_warn true
list_set_searchable true

while true;do
	# Get selection
	list_select ${_LOCAL_LIST}
	[[ ${?} -eq 0 ]] && break

	# Get selections
	_MARKED=($(list_get_selected))
	
	if [[ $(list_get_selected_count) -gt 1 ]];then
		action_warn ${_MARKED} # Warn if more than 1 selected
	fi
 
 	if [[ ${_MSG_KEY} == "y" || $(list_get_selected_count) -eq 1 ]];then
 		action_do ${_MARKED}
 	fi
done

exit_leave
