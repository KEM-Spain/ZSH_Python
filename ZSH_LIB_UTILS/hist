#!/usr/bin/zsh
#Inline ansi
BOLD="\033[1m"
ITALIC="\033[3m"
RESET="\033[m"
REVERSE="\033[7m"
STRIKE="\033[9m"
UNDER="\033[4m"
BLACK_BG="\033[40m"
BLUE_FG="\033[34m"
CYAN_FG="\033[36m"
GREEN_FG="\033[32m"
MAGENTA_FG="\033[35m"
RED_FG="\033[31m"
WHITE_FG="\033[37m"
YELLOW_FG="\033[33m"
WHITE_ON_GREY="\033[0m\033[0;1;37;100m"

# Imports
_LIB_DIR=${ZSH_LIB_DIR:=/usr/local/lib}
source ${_LIB_DIR}/LIB_INIT.zsh # Must be first
source ${_LIB_DIR}/UTILS.zsh
source ${_LIB_DIR}/LIST.zsh
source ${_LIB_DIR}/LIB_DEPS.zsh # Must be last
 
# Constants
_HIST_FILE=~/.zsh_history
_LAST_ACTION=/tmp/hist_action
_OBJ_TYPE="command"

# Declarations
typeset -a _HIST_LIST=()

# Vars
_ALL=false
_HIST_MAX=46
_SEARCHTERM=''
_DELETE=false
_HIST_KEY=''
_SCRIPT=${0:t}
_ACTION_MSG=''

# Functions
action_do () {
	local M L
	local RC
	local NDX=0
	local LINE_NO=''
	local LINE_TEXT=''
	local HIST_NEW="/tmp/${_HIST_FILE:t}.new"
	local SED_CMD=''
	local B_LINES=0
	local A_LINES=0

	msg_box -t.5 "Removing ${#_MARKED} lines from history"

	for M in ${_MARKED};do
		list_set_selected ${M} ${_STALE_ROW}
	done

	cp ${_HIST_FILE} ${HIST_NEW}

	for L in ${_HIST_LIST};do
		LINE_NO=$(cut -d: -f1 <<<${L})
		if [[ -z ${_SEARCHTERM} ]];then
			[[ ${_MARKED[(i)${LINE_NO}]} -le ${#_MARKED} ]] || continue
		fi
		SED_CMD+="${LINE_NO}d;"
	done

	sed -i -e ${SED_CMD} ${HIST_NEW}

	B_LINES=$(wc -l ${_HIST_FILE} | cut -d' ' -f1)
	A_LINES=$(wc -l ${HIST_NEW} | cut -d' ' -f1)
	msg_box -p -P"Save modified history (y/n)?" "History file lines reduced from ${B_LINES} to ${A_LINES}"
	if [[ ${_MSG_KEY} == 'y' ]];then
		cp ${HIST_NEW} ${_HIST_FILE}
	else
		for M in ${_MARKED};do
			list_set_selected ${M} ${_AVALABLE_ROW}
		done
	fi
}

action_warn () {
	local CNT=$(list_get_selected_count)
	local M 
	local -a DLIST
	local FN
	local HDRS=2
	
	msg_box "Working..."
	for M in ${_MARKED};do
		[[ ${_LOCAL_LIST[${M}]:h} == ${PWD} ]] && FN=${_LOCAL_LIST[${M}]:t} || FN=${_LOCAL_LIST[${M}]}
		DLIST+=${FN}
	done

	[[ -n ${_OFFSCREEN_ROWS_MSG} ]] && ((HDRS++))

	msg_box -O${RED_FG} -H${HDRS} -x10 -c -p -PD "<I><w>Please respond...<N>|$(str_pluralize ${OBJTYPE} ${CNT} true) queued for deletion|${_OFFSCREEN_ROWS_MSG}|$(msg_list_bullet ${(o)DLIST})"

	if [[ ${_MSG_KEY} == 'n' ]];then
		for M in ${_MARKED};do
			list_clear_selected ${M}
		done
	fi
}

item_decorate () {
	local NDX=${1}
	local _MAX=$(( _MAX_COLS - 10 ))
	local CMD=''
	local TM=''
	local DATE=''
	local LINE_NO=''

	LINE_NO=$(cut -d: -f1 <<< ${_LIST[${NDX}]})
	TM=$(cut -d: -f3 <<< ${_LIST[${NDX}]})
	CMD=$(cut -d: -f4- <<< ${_LIST[${NDX}]} | cut -d';' -f2-)
	DATE=$(date -d @${TM} +%Y-%m-%d)

	case ${_LIST_SELECTED[${NDX}]} in
		2) echo -n "${DATE}#${E_STRIKE}${E_RED_FG}${CMD}${E_RESET} ${E_ITALIC}deleted${E_RESET}";;
		*) echo "${DATE}#${CMD}";;
	esac
}

collect_hist () {
	local SEARCHTERM=${1}
	local NDX=0

	if [[ -n ${SEARCHTERM} ]];then
		grep --color=never -n ${SEARCHTERM} ${_HIST_FILE}
	else
		while read LINE;do
			((NDX++))
			echo ${NDX}:${LINE}
		done < ${_HIST_FILE}
	fi
}

#--Begin GetOpts--
local -a OPTIONS
local OPTION
local DESC

read -r -d '' DESC<<EOF
Display command line history
EOF

parse_opts () {
	local OPTS=${@}
	local -a OPTSTR
	local LETTER_OPT
	local O

	for O in {1..${#OPTS}};do
		[[ ${OPTS[${O}]} =~ '[A-Za-z]' ]] && LETTER_OPT=${OPTS[${O}]}
		[[ ${O} -eq 1 && ${OPTS[${O}]} == ":" ]] && continue
		[[ ${O} -gt 1 && ${OPTS[${O}]} == ":" ]] && OPTSTR+=$(opt_type ${LETTER_OPT}) && continue
		OPTSTR+="-${OPTS[${O}]}"
	done
	echo ${OPTSTR}
}

opt_exists () {
	local OPT=${1}
	[[ $(( $OPTIONS[(Ie)${OPT}] )) -ne 0 ]] && return 0 || return 1
}

opt_type () {
	local OPT=${1}
	case ${OPT} in
		n) echo "<LINES>";;
		f) echo "<FILE>";;
	esac
}

usage () {
	local -a PENDING_MSGS=(${@})
	local OPTS=$(parse_opts ${OPTSTR})

	[[ ${_SMCUP} == 'true' ]] && do_rmcup

	tabs 5
	(
	echo -e "\n${WHITE_FG}\nUsage${RESET}: ${_SCRIPT} ${WHITE_FG}[${RESET}${OPTS}${WHITE_FG}]${RESET} [SEARCHTERM]\n"
	echo -e "${WHITE_FG}-H${RESET} help"
	echo -e "${WHITE_FG}-D${RESET} debug (repeats increase level)"
	echo -e "${WHITE_FG}-a${RESET} all history lines"
	echo -e "${WHITE_FG}-n${RESET} history lines (default: ${_HIST_MAX})"
	echo -e "\n${WHITE_FG}DESC${RESET}:${DESC}"
	) >&2

	exit_leave $(err_msg_exit ${PENDING_MSGS})
}

OPTSTR=":HDan:"
OPTIND=0

HIST_MAX_OPT=''

while getopts ${OPTSTR} OPTION;do
	case $OPTION in
     H) usage;;
     D) dbg_set_level;;
	  a) _ALL=true;;
	  n) _HIST_MAX_OPT=${OPTARG};;
     :) print -u2 "${RED_FG}${_SCRIPT}${RESET}: option: -${OPTARG} requires an argument"; usage;;
    \?) print -u2 "${RED_FG}${_SCRIPT}${RESET}: unknown option -${OPTARG}"; usage;;
	esac
	[[ ${OPTION} != 'D' ]] && OPTIONS+=${OPTION}
done
shift $(( OPTIND - 1 ))
#--End GetOpts--

# Execution
[[ ${_DEBUG} -eq 0 ]] && do_smcup

[[ -n ${1} ]] && _SEARCHTERM=${1}

if [[ -n ${HIST_MAX_OPT} ]];then
	if ! validate_is_integer ${_HIST_MAX};then
		exit_leave $(err_msg_exit E "Option <-n> invalid - integer required")
	else
		_HIST_MAX=${HIST_MAX_OPT}
	fi
fi

msg_box "<w>Collecting history...<N>"
_HIST_LIST=("${(f)$(collect_hist ${_SEARCHTERM})}")

if ! arr_is_populated "${_HIST_LIST}";then
	if [[ -n ${_SEARCHTERM} ]];then
		exit_leave "No history lines matched SEARCHTERM:${SEARCHTERM}"
	else
		exit_leave "No history lines found"
	fi
fi

# Set headings
list_set_header 'printf "Found:${WHITE_FG}%-d${RESET} $(str_pluralize ${_OBJ_TYPE} ${#_LIST}) Filter:${WHITE_FG}%s${RESET}  Selected:${WHITE_FG}%-d${RESET}  ${_PG}" ${#_LIST} "${_SEARCHTERM:=None}" ${SELECTED_COUNT}'
list_add_header_break
list_set_header_break_color ${RED_FG}

# Set line item
list_set_line_item ' 
local D C;
D=$(item_decorate ${_LIST_NDX} | cut -d'#' -f1)
C=$(item_decorate ${_LIST_NDX} | cut -d'#' -f2-)
printf "${BOLD}${WHITE_FG}%4s${RESET}${_MARKER} ${SHADE}${BAR}${CYAN_FG}%s${RESET} %s\n" ${_LIST_NDX} ${D} "${C}"
'

list_set_select_action "delete"
list_set_action_msgs delete command
list_set_searchable true

while true;do
	# Display list
	list_select ${(onv)_HIST_LIST}
	RC=${?}

	[[ ${RC} -eq 0 ]] && break

	# Get user selections
	_MARKED=($(list_get_selected))
	
	if [[ $(list_get_selected_count) -ne 0 ]];then
		action_warn
		if [[ ${_MSG_KEY} == "y" ]];then
			action_do
		fi
	fi
done

exit_leave
